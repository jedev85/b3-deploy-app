{% extends 'base.html.twig' %}

{% block title %}Applications - DeployLab{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Applications</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a class="button" href="{{ path('app_application_new') }}">Nouvelle application</a>
        {% endif %}
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Depot</th>
                <th>Criticite</th>
                <th>Environnements</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for application in applications %}
                <tr>
                    <td><a href="{{ path('app_application_show', { id: application.id }) }}">{{ application.name }}</a></td>
                    <td><a href="{{ application.repositoryUrl }}" target="_blank" rel="noreferrer">{{ application.repositoryUrl }}</a></td>
                    <td><span class="badge badge--{{ application.criticality }}">{{ application.criticality }}</span></td>
                    <td>{{ application.environments|length }}</td>
                    <td><a href="{{ path('app_application_show', { id: application.id }) }}">Voir</a></td>
                </tr>
            {% else %}
                <tr><td colspan="5">Aucune application.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
